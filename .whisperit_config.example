"""
Example Configuration File (Optional)
Save as .whisperit_config if you want to set persistent default values.
Not required for basic usage.
"""

# Default model - one of: tiny, base, small, medium, large
DEFAULT_MODEL = "base"

# Default language - use 'auto' for auto-detection
# See transcriber.py LANGUAGES dict for full list
DEFAULT_LANGUAGE = "auto"

# Output directory (set to 'default' to use ~/Transcriptions)
OUTPUT_DIRECTORY = "default"

# Output formats - list of: txt, json, tsv
OUTPUT_FORMATS = ["txt", "json", "tsv"]

# Save summary JSON? (True/False)
SAVE_SUMMARY = True
